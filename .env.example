# OpenSentinel - Environment Variables
# Copy this file to .env and fill in values.

# Required API keys
NVIDIA_API_KEY=
TAVILY_API_KEY=

# Optional API keys (set only if you use these providers)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
LANGSMITH_API_KEY=

# No longer needed - weather tool uses free Open-Meteo API
# OPENWEATHERMAP_API_KEY=

# Model configuration
# Supports provider:model syntax (e.g., nvidia:qwen/qwen3.5-397b-a17b)
OPENSENTINEL_MODEL_NAME=qwen/qwen3.5-122b-a10b
OPENSENTINEL_FALLBACK_MODEL=meta/llama-3.3-70b-instruct
# OPENSENTINEL_SUBAGENT_MODEL_NAME=qwen/qwen3.5-122b-a10b
OPENSENTINEL_MODEL_TEMPERATURE=0.3
OPENSENTINEL_MODEL_MAX_TOKENS=8192
OPENSENTINEL_MODEL_TIMEOUT=120

# Security judge (LLM-based semantic classifier for guardrails)
OPENSENTINEL_ENABLE_JUDGE=true
# OPENSENTINEL_JUDGE_MODEL_NAME=qwen/qwen3.5-122b-a10b  # defaults to base model
OPENSENTINEL_JUDGE_TIMEOUT=15

# Runtime settings
ENVIRONMENT=development
LOG_LEVEL=INFO
CACHE_ENABLED=true
CACHE_BACKEND=memory
CACHE_TTL=3600

# Redis cache (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_USERNAME=

# Local Ollama fallback (optional)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Postgres checkpointer (prepared but not wired by default)
LANGGRAPH_CHECKPOINT_ENABLED=false
LANGGRAPH_CHECKPOINT_DATABASE_URL=postgresql://postgres:pass@localhost:5432/fastapi
LANGGRAPH_CHECKPOINT_AUTOCOMMIT=true

# Sandbox configuration (secure command execution for /workspace/)
# OPENSENTINEL_WORKSPACE_DIR=/tmp/opensentinel_workspace  # defaults to OS temp dir
OPENSENTINEL_SANDBOX_TIMEOUT=60000
OPENSENTINEL_SANDBOX_MAX_OUTPUT=50000
OPENSENTINEL_SANDBOX_DEBUG=false

# LangGraph deployment config
# Allows blocking I/O operations (needed for SkillsMiddleware file operations)
BG_JOB_ISOLATED_LOOPS=true
